{
	"name": "medical-chaperon-miniapp",
	"version": "1.0.0",
	"private": true,
	"description": "医疗陪诊微信小程序 - 提供陪诊预约、患者管理、课程视频、AI助手等服务",
	"templateInfo": {
		"name": "react-NutUI",
		"typescript": false,
		"css": "Sass",
		"framework": "React"
	},
	"scripts": {
		"build:weapp": "taro build --type weapp",
		"build:swan": "taro build --type swan",
		"build:alipay": "taro build --type alipay",
		"build:tt": "taro build --type tt",
		"build:h5": "taro build --type h5",
		"build:rn": "taro build --type rn",
		"build:qq": "taro build --type qq",
		"build:jd": "taro build --type jd",
		"build:quickapp": "taro build --type quickapp",
		"dev:weapp": "npm run build:weapp -- --watch",
		"dev:swan": "npm run build:swan -- --watch",
		"dev:alipay": "npm run build:alipay -- --watch",
		"dev:tt": "npm run build:tt -- --watch",
		"dev:h5": "npm run build:h5 -- --watch",
		"dev:rn": "npm run build:rn -- --watch",
		"dev:qq": "npm run build:qq -- --watch",
		"dev:jd": "npm run build:jd -- --watch",
		"dev:quickapp": "npm run build:quickapp -- --watch",
		"format": "prettier --write \"src/**/*.{js,jsx,scss,json}\"",
		"format:check": "prettier --check \"src/**/*.{js,jsx,scss,json}\"",
		"lint": "eslint src --ext .js,.jsx",
		"lint:fix": "eslint src --ext .js,.jsx --fix && prettier --write \"src/**/*.{js,jsx,scss,json}\"",
		"lint:unused": "eslint src --ext .js,.jsx --rule 'no-unused-vars: error' --rule 'import/no-unused-modules: error'",
		"test": "jest --passWithNoTests",
		"test:coverage": "jest --coverage --passWithNoTests",
		"prepare": "husky install"
	},
	"browserslist": [
		"last 3 versions",
		"Android >= 4.1",
		"ios >= 8"
	],
	"author": "Medical Chaperon Team",
	"lint-staged": {
		"src/**/*.{js,jsx}": [
			"eslint --fix",
			"prettier --write"
		],
		"src/**/*.{scss,json}": [
			"prettier --write"
		]
	},
	"dependencies": {
		"@babel/runtime": "^7.21.5",
		"@nutui/nutui-react-taro": "3.0.17",
		"@tarojs/components": "4.1.5",
		"@tarojs/helper": "4.1.5",
		"@tarojs/plugin-framework-react": "4.1.5",
		"@tarojs/plugin-html": "4.1.5",
		"@tarojs/plugin-platform-alipay": "4.1.5",
		"@tarojs/plugin-platform-h5": "4.1.5",
		"@tarojs/plugin-platform-jd": "4.1.5",
		"@tarojs/plugin-platform-qq": "4.1.5",
		"@tarojs/plugin-platform-swan": "4.1.5",
		"@tarojs/plugin-platform-tt": "4.1.5",
		"@tarojs/plugin-platform-weapp": "4.1.5",
		"@tarojs/react": "4.1.5",
		"@tarojs/runtime": "4.1.5",
		"@tarojs/shared": "4.1.5",
		"@tarojs/taro": "4.1.5",
		"ajv": "^8.12.0",
		"react": "^18.0.0",
		"react-dom": "^18.0.0",
		"react-transition-group": "^4.4.5",
		"zustand": "^5.0.6"
	},
	"devDependencies": {
		"@babel/core": "^7.8.0",
		"@babel/plugin-proposal-class-properties": "7.14.5",
		"@babel/preset-env": "^7.28.5",
		"@babel/preset-react": "^7.28.5",
		"@pmmmwh/react-refresh-webpack-plugin": "^0.5.5",
		"@tarojs/cli": "4.1.5",
		"@tarojs/taro-loader": "4.1.5",
		"@tarojs/webpack5-runner": "4.1.5",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.1",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^18.15.11",
		"@types/react": "^18.0.0",
		"@types/webpack-env": "^1.13.6",
		"babel-jest": "^30.2.0",
		"babel-plugin-import": "^1.13.8",
		"babel-plugin-transform-remove-console": "^6.9.4",
		"babel-preset-taro": "4.1.5",
		"eslint": "^8.12.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-config-taro": "4.1.5",
		"eslint-import-resolver-alias": "^1.1.2",
		"eslint-plugin-import": "^2.12.0",
		"eslint-plugin-prettier": "^5.1.3",
		"eslint-plugin-react": "^7.8.2",
		"eslint-plugin-react-hooks": "^4.2.0",
		"husky": "^9.1.7",
		"jest": "^30.2.0",
		"jest-environment-jsdom": "^30.4.1",
		"lint-staged": "^16.4.0",
		"postcss": "^8.4.18",
		"prettier": "^3.2.5",
		"react-refresh": "^0.11.0",
		"stylelint": "^14.4.0",
		"stylelint-config-prettier": "^9.0.5",
		"ts-node": "^10.9.1",
		"typescript": "^6.0.3",
		"webpack": "5.78.0"
	}
}
